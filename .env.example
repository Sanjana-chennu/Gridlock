# Gemini API key (free at aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# MapMyIndia (Mappls) REST API key — get from https://about.mappls.com/api/
# Used for: satellite imagery + nearby POI context for BBMP proposals
MAPPLS_API_KEY=your_mappls_api_key_here

# Optional
DATA_MODE=real
